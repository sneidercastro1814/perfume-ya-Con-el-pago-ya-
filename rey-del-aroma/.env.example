# ─────────────────────────────────────────────────────────────
# .env.example — copia este archivo a ".env" para desarrollo local.
# AQUÍ SOLO VAN VALORES PÚBLICOS (los que empiezan por VITE_ terminan
# dentro del JavaScript que ve el navegador, así que NO son secretos).
# ─────────────────────────────────────────────────────────────

# Llave PÚBLICA de Wompi (pub_prod_... en producción, pub_test_... en pruebas)
VITE_WOMPI_PUBLIC_KEY=pub_prod_TU_LLAVE_PUBLICA

# Entorno de Wompi: "prod" (producción) o "test" (sandbox/pruebas)
VITE_WOMPI_ENV=prod

# Addi
VITE_ADDI_ENABLED=true
VITE_ADDI_SLUG=reydelaroma-ecommerce

# Sistecrédito (opcional). Déjalo vacío para ocultar el método.
VITE_SISTECREDITO_ENABLED=false
VITE_SISTECREDITO_URL=

# ─────────────────────────────────────────────────────────────
# ⚠️  LOS SECRETOS NO VAN AQUÍ NI EN EL REPO. Se configuran ÚNICAMENTE
#     en Netlify → Site settings → Environment variables:
#       WOMPI_INTEGRITY_SECRET   (prod_integrity_...)
#       WOMPI_EVENTS_SECRET      (prod_events_...)
#       WOMPI_PRIVATE_KEY        (prv_prod_...)   ← opcional, para consultas avanzadas
#       ADDI_CLIENT_ID
#       ADDI_CLIENT_SECRET
# ─────────────────────────────────────────────────────────────
